<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="view_model"
            type="com.example.app21try6.stock.upsertproduk.UpsertProductViewModel" />

    </data>

        <!-- TODO: Update blank fragment layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">
            <ScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                tools:context=".stock.upsertproduk.InputUpdateProduct">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="@dimen/medium_margin"
                    >
                    <LinearLayout
                        android:layout_width="300dp"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/medium_margin"
                        android:layout_marginEnd="@dimen/small_margin"
                        android:layout_marginBottom="@dimen/big_margin"
                        android:id="@+id/lbl_id"
                        >
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ID: "
                            />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/txt_id"
                            />
                    </LinearLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_marginBottom="@dimen/medium_margin"
                        android:id="@+id/il_ket"
                        android:hint="Produk"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="true"
                            android:text="@={view_model.productName}"
                            android:focusableInTouchMode="true"
                            android:id="@+id/textUpdateKet"
                            />
                    </com.google.android.material.textfield.TextInputLayout>
                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_marginBottom="@dimen/medium_margin"
                       android:orientation="horizontal">
                       <com.google.android.material.textfield.TextInputLayout
                           android:layout_width="0dp"
                           android:layout_weight="1"
                           android:id="@+id/il_cat"
                           android:hint="kategori"
                           android:layout_marginEnd="@dimen/small_margin"
                           android:layout_height="wrap_content">
                           <AutoCompleteTextView
                               android:id="@+id/text_category"
                               android:layout_width="match_parent"
                               android:layout_height="60dp"
                               android:paddingStart="@dimen/big_margin"
                               android:paddingEnd="@dimen/big_margin"
                               android:inputType="text"
                               android:text="@={view_model.ctgName}"
                               />
                       </com.google.android.material.textfield.TextInputLayout>
                       <com.google.android.material.textfield.TextInputLayout
                           android:layout_width="0dp"
                           android:layout_weight="1"
                           android:id="@+id/il_brand"
                           android:hint="Brand"
                           android:layout_height="wrap_content">
                           <AutoCompleteTextView
                               android:id="@+id/text_brand"
                               android:layout_width="match_parent"
                               android:layout_height="60dp"
                               android:paddingStart="@dimen/big_margin"
                               android:paddingEnd="@dimen/big_margin"
                               android:inputType="text"
                               android:text="@={view_model.branName}"
                               />
                       </com.google.android.material.textfield.TextInputLayout>
                   </LinearLayout>

                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_marginBottom="@dimen/medium_margin"
                       android:orientation="horizontal">
                       <com.google.android.material.textfield.TextInputLayout
                           android:layout_width="0dp"
                           android:layout_weight="1"
                           android:id="@+id/il_price"
                           android:layout_marginEnd="@dimen/small_margin"
                           android:hint="Harga Jual"
                           android:layout_height="wrap_content">
                           <com.google.android.material.textfield.TextInputEditText
                               android:layout_width="match_parent"
                               android:layout_height="wrap_content"
                               android:id="@+id/textUpdatePrice"
                               android:inputType="number"
                               app:rupiahValue="@={view_model.productPice}"
                               />
                       </com.google.android.material.textfield.TextInputLayout>

                       <com.google.android.material.textfield.TextInputLayout
                           android:layout_width="0dp"
                           android:id="@+id/il_alternate_price"
                           android:hint="Harga Alternatif"
                           android:layout_weight="1"
                           android:layout_height="wrap_content">
                           <com.google.android.material.textfield.TextInputEditText
                               android:layout_width="match_parent"
                               android:layout_height="wrap_content"
                               android:id="@+id/textUpdateAlternatePrice"
                               android:inputType="number"
                               app:rupiahValue="@={view_model.alternatePrice}"
                               />
                       </com.google.android.material.textfield.TextInputLayout>
                   </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:id="@+id/il_disc"
                        android:hint="Diskon"
                        android:layout_marginBottom="@dimen/medium_margin"
                        android:layout_height="wrap_content">
                        <AutoCompleteTextView
                            android:id="@+id/text_discount"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:paddingStart="@dimen/big_margin"
                            android:paddingEnd="@dimen/big_margin"
                            android:inputType="text"
                            android:text="@={view_model.discountName}"
                            />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/medium_margin"
                        android:orientation="horizontal">
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/small_margin"
                            android:id="@+id/il_purchase_price"
                            android:hint="Harga Beli"
                            android:layout_height="wrap_content">
                            <com.google.android.material.textfield.TextInputEditText
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/purchase_price"
                                android:inputType="number"
                                app:rupiahValue="@={view_model.purchasePrice}"
                                />
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/small_margin"
                            android:layout_marginBottom="@dimen/small_margin"
                            android:id="@+id/il_capital"
                            android:hint="Modal"
                            android:layout_height="wrap_content">
                            <com.google.android.material.textfield.TextInputEditText
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/textCapital"
                                android:inputType="number"
                                app:rupiahValue="@={view_model.productCapital}"
                                />
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/small_margin"
                            android:layout_marginBottom="@dimen/small_margin"
                            android:id="@+id/il_capital2"
                            android:hint="Modal Alternatif"
                            android:layout_height="wrap_content">
                            <com.google.android.material.textfield.TextInputEditText
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/textCapital2"
                                android:inputType="number"
                                app:rupiahValue="@={view_model.alternateCapital}"
                                />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/big_margin"
                        android:orientation="horizontal">
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/small_margin"
                            android:id="@+id/il_default_net"
                            android:hint="Net Modus"
                            android:layout_height="wrap_content">
                            <com.google.android.material.textfield.TextInputEditText
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/default_net"
                                android:inputType="numberDecimal"
                                app:doubleText="@={view_model.defaultNet}"
                                />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/small_margin"
                            android:layout_marginBottom="@dimen/small_margin"
                            android:id="@+id/il_purchase_unit"
                            android:hint="Unit"
                            android:layout_height="wrap_content">
                            <com.google.android.material.textfield.TextInputEditText
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/purchase_unit"
                                android:text="@={view_model.puchaseUnit}"
                                />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>


                    <Button
                        android:layout_width="300dp"
                        android:layout_height="wrap_content"
                        android:onClick="@{()->view_model.onBtnSimpanClick()}"
                        android:text="Simpan"
                        />
                </LinearLayout>
            </ScrollView>
            <ScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="@dimen/big_margin"
                tools:context=".stock.upsertproduk.InputUpdateProduct">
                <LinearLayout
                    android:layout_margin="@dimen/medium_margin"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <TextView
                        style="@style/active_transaction_text_style"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/big_margin"
                        android:text="Informasi Terkait Produk"
                        />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            style="@style/active_transaction_text_style"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/big_margin"
                            android:onClick="@{()->view_model.onStartDatePickerClick()}"
                            android:text="@{view_model._dateRangeString}"
                            />
                        <ImageView
                            android:id="@+id/cal_icon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_margin="@dimen/medium_margin"
                            android:elevation="@dimen/medium_margin"
                            android:onClick="@{()->view_model.onStartDatePickerClick()}"
                            android:src="@drawable/baseline_calendar_month_24"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </LinearLayout>



                    <TextView
                        style="@style/active_transaction_text_style"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/medium_margin"
                        android:text='@{"Total Terjual: " + view_model.qtyPerProduct}'
                        />

                    <TextView
                        style="@style/active_transaction_text_style"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/medium_margin"
                        android:text='@{"Banyak Transaksi: " + view_model.productTransactionCount}'
                        />

                    <TextView
                        style="@style/active_transaction_text_style"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/medium_margin"
                        android:text='@{"Jumlah Pembeli: " + view_model.customerPerProductCount}'
                        />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            style="@style/active_transaction_text_style"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Modus Laku:"
                            android:layout_marginEnd="@dimen/big_margin"
                            />
                        <LinearLayout
                            android:id="@+id/modus_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/medium_margin"
                            android:orientation="vertical"
                            android:layout_marginTop="@dimen/small_margin"
                            app:modusList="@{view_model.productModusList}"
                            />

                    </LinearLayout>

                    <TextView
                        style="@style/active_transaction_text_style"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pengaturan Lanjutan "
                        android:layout_marginBottom="@dimen/big_margin"
                        />
                    <TextView
                        style="@style/active_transaction_text_style"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ubah Modal di Transaksi "
                        android:layout_marginBottom="@dimen/medium_margin"
                        />
                    <TextView
                        style="@style/active_transaction_small_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Peringatan: Perubahan data bersifat permanen, setelah diubah tidak dapat dikembaikan lagi "
                        />

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

</layout>