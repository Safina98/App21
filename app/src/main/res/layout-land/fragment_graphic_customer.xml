<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <Spinner
            android:id="@+id/spinner_tahun_cg"
            android:layout_width="638dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Spinner
            android:id="@+id/spinner_bulan_cg"
            android:layout_width="639dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />



        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/bar_chart_cg"
            android:layout_width="0dp"
            android:layout_height="500dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            app:layout_constraintEnd_toStartOf="@+id/rv_chart_cg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/spinner_tahun_cg" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chart_cg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="3dp"
            android:visibility="visible"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/bar_chart_cg"
            app:layout_constraintTop_toBottomOf="@id/spinner_tahun_cg" />



    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>